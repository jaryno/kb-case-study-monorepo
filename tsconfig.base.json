{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@bookbot/constants": ["packages/constants/src/index.ts"],
      "@bookbot/book-utils": ["packages/book-utils/src/index.ts"],
      "@bookbot/db": ["packages/db/src/index.ts"]
    },
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@bookbot/source"]
  }
}
